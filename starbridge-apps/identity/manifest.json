{
  "id": "identity",
  "name": "Identity",
  "description": "Credential issuance and selective disclosure starbridge-app (dregg-native).",
  "version": "0.1.0",
  "factory_vks": [
    "737461726272696467652d6964656e746974792d6973737565722d6661637421"
  ],
  "page": "/starbridge-apps/identity/pages/index.html",
  "inspectors": [
    "credential",
    "credential-issue-form",
    "credential-present-form",
    "credential-verifier"
  ],
  "host_inspectors": [
    { "id": "credential", "label": "Credential", "tag": "dregg-credential", "uri_attribute": "uri" },
    { "id": "issue", "label": "Issue", "tag": "dregg-credential-issue-form", "uri_attribute": "issuer-uri" },
    { "id": "present", "label": "Present", "tag": "dregg-credential-present-form", "uri_attribute": "credential-uri" },
    { "id": "verify", "label": "Verify", "tag": "dregg-credential-verifier", "uri_attribute": "presentation-uri" }
  ],
  "host_actions": [
    { "id": "inspect_issuer", "label": "Inspect issuer", "uri": "dregg://cell/identity-issuer-default", "kind": "inspect" },
    { "id": "issue_credential", "label": "Issue credential", "builder": "issue_credential", "kind": "turn" },
    { "id": "revoke_credential", "label": "Revoke credential", "builder": "revoke_credential", "kind": "turn" },
    { "id": "present_credential", "label": "Present credential", "builder": "present_credential", "kind": "local" },
    { "id": "verify_presentation", "label": "Verify presentation", "builder": "verify_presentation", "kind": "turn" }
  ],
  "host_controls": [
    { "id": "issuer_uri", "label": "Issuer URI", "type": "uri", "default": "dregg://cell/identity-issuer-default" },
    { "id": "privacy", "label": "Disclosure", "type": "select", "options": ["selective", "full"], "default": "selective" }
  ],
  "turn_builders": [
    "issue_credential",
    "revoke_credential",
    "present_credential",
    "verify_presentation"
  ],
  "required_apis": [
    "signTurn",
    "blake3",
    "cell.readField",
    "builders.identity"
  ],
  "slot_layout": {
    "SCHEMA_COMMITMENT_SLOT": 2,
    "ISSUANCE_COUNTER_SLOT": 3,
    "REVOCATION_ROOT_SLOT": 4,
    "ISSUER_AUTH_ROOT_SLOT": 5
  },
  "state_constraints": [
    "Immutable(SCHEMA_COMMITMENT_SLOT)",
    "MonotonicSequence(ISSUANCE_COUNTER_SLOT)",
    "Monotonic(REVOCATION_ROOT_SLOT)",
    "SenderAuthorized(PublicRoot(ISSUER_AUTH_ROOT_SLOT))"
  ],
  "manifest_health": {
    "status": "ready",
    "embedded": true,
    "source_of_truth": "starbridge-apps/identity/src/lib.rs"
  }
}
