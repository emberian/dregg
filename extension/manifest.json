{
  "manifest_version": 3,
  "name": "Pyana Wallet",
  "version": "0.1.0",
  "description": "Capability-based authorization wallet with zero-knowledge proofs",
  "permissions": ["storage", "activeTab", "contextMenus"],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["dist/content.js"],
    "run_at": "document_start"
  }],
  "web_accessible_resources": [{
    "resources": ["dist/page.js", "bip39_english.txt", "pyana_wasm.js", "pyana_wasm_bg.wasm"],
    "matches": ["<all_urls>"]
  }],
  "action": {
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
