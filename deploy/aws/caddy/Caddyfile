devnet.dregg.fg-goose.online, dregg.fg-goose.online {
    # HTTP API
    handle /api/* {
        reverse_proxy localhost:8420
    }

    # WebSocket endpoint
    handle /ws {
        reverse_proxy localhost:8420
    }

    # Node status/health
    handle /status {
        reverse_proxy localhost:8420
    }

    # Federation endpoints
    handle /federation/* {
        reverse_proxy localhost:8420
    }

    # Programmable queue endpoints
    handle /queues/* {
        reverse_proxy localhost:8420
    }

    # Checkpoint endpoints
    handle /checkpoint/* {
        reverse_proxy localhost:8420
    }

    # PIR endpoints
    handle /pir/* {
        reverse_proxy localhost:8420
    }

    # Wallet endpoints
    handle /cipherclerk {
        reverse_proxy localhost:8420
    }

    # Discord bot Starbridge RemoteRuntime read surface
    handle /discord-bot/api/* {
        uri strip_prefix /discord-bot
        reverse_proxy localhost:8080
    }
    handle /discord-bot/observability/stream {
        uri strip_prefix /discord-bot
        reverse_proxy localhost:8080
    }

    # Faucet
    handle /faucet/* {
        reverse_proxy localhost:8420
    }

    # Governed Namespace (service mesh)
    handle /namespace/* {
        reverse_proxy localhost:3003
    }
    handle /app/namespace/* {
        root * /opt/dregg/apps/governed-namespace/frontend
        file_server
    }

    # Chain explorer (built static files; deep links fall back to SPA shell)
    handle /explorer* {
        root * /opt/dregg/site/dist
        try_files {path} {path}/ /explorer/index.html
        file_server
    }

    # Playground (built static files)
    handle /playground* {
        root * /opt/dregg/site/dist
        try_files {path} {path}/ /playground/index.html /playground.html
        file_server
    }

    # Starbridge app shell (single built page; support /starbridge and /starbridge/)
    @starbridge_shell path /starbridge /starbridge/
    handle @starbridge_shell {
        root * /opt/dregg/site/dist
        try_files /starbridge.html
        file_server
    }

    # Built site root
    handle {
        root * /opt/dregg/site/dist
        try_files {path} {path}.html {path}/ /index.html
        file_server
    }

    # CORS headers for browser clients.
    #
    # RECOMMENDED (CORS-free) path: this Caddyfile already reverse-proxies the
    # node API (/api/*, /status, /ws, /federation/*, ...) AND serves the built
    # site (/explorer, /playground, /starbridge, /) from the SAME origin
    # (devnet.dregg.fg-goose.online). Same-origin requests are not subject to
    # CORS at all, so a browser on the deployed site talks to the node without
    # any Access-Control-* negotiation. The headers below remain for any
    # genuinely cross-origin client. If you instead point the browser directly
    # at the node on another origin, set DREGG_CORS_ORIGINS (or --cors-origin)
    # on dregg-node to that site origin so the node echoes it back.
    header Access-Control-Allow-Origin "*"
    header Access-Control-Allow-Methods "GET, POST, OPTIONS"
    header Access-Control-Allow-Headers "Content-Type, Authorization"

    # Security headers
    header X-Content-Type-Options "nosniff"
    # SAMEORIGIN (not DENY) so the deployed site can embed its OWN app iframes
    # (the chain explorer / playground / starbridge shells are framed by the
    # site shell). CSP frame-ancestors 'self' is the modern equivalent and
    # supersedes X-Frame-Options in browsers that honor it; both are set so
    # older and newer browsers agree on "self may frame, others may not."
    header X-Frame-Options "SAMEORIGIN"
    header Content-Security-Policy "frame-ancestors 'self'"
    header Referrer-Policy "strict-origin-when-cross-origin"
}
