devnet.dregg.fg-goose.online {
    # HTTP API
    handle /api/* {
        reverse_proxy localhost:8420
    }

    # WebSocket endpoint
    handle /ws {
        reverse_proxy localhost:8420
    }

    # Node status/health
    handle /status {
        reverse_proxy localhost:8420
    }

    # Federation endpoints
    handle /federation/* {
        reverse_proxy localhost:8420
    }

    # Checkpoint endpoints
    handle /checkpoint/* {
        reverse_proxy localhost:8420
    }

    # PIR endpoints
    handle /pir/* {
        reverse_proxy localhost:8420
    }

    # Wallet endpoints
    handle /cipherclerk {
        reverse_proxy localhost:8420
    }

    # Discord bot Starbridge RemoteRuntime read surface
    handle /discord-bot/api/* {
        uri strip_prefix /discord-bot
        reverse_proxy localhost:8080
    }
    handle /discord-bot/observability/stream {
        uri strip_prefix /discord-bot
        reverse_proxy localhost:8080
    }

    # Faucet
    handle /faucet/* {
        reverse_proxy localhost:8420
    }

    # Governed Namespace (service mesh)
    handle /namespace/* {
        reverse_proxy localhost:3003
    }
    handle /app/namespace/* {
        root * /opt/dregg/apps/governed-namespace/frontend
        file_server
    }

    # Chain explorer (static files)
    handle /explorer/* {
        root * /opt/dregg/site
        file_server
    }

    # Playground (static files)
    handle /playground/* {
        root * /opt/dregg/site
        file_server
    }

    # Root serves explorer by default
    handle {
        root * /opt/dregg/site/explorer
        file_server
    }

    # CORS headers for browser clients
    header Access-Control-Allow-Origin "*"
    header Access-Control-Allow-Methods "GET, POST, OPTIONS"
    header Access-Control-Allow-Headers "Content-Type, Authorization"

    # Security headers
    header X-Content-Type-Options "nosniff"
    header X-Frame-Options "DENY"
    header Referrer-Policy "strict-origin-when-cross-origin"
}
